<Window x:Class="SqlServerExportTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SQL Server 定时导出工具"
        Width="1260"
        Height="900"
        MinWidth="1080"
        MinHeight="760"
        Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FFF5F1E8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFCF7" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF174A62" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#FFDDEAF0" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#FFE2D8C8" />
        <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="20,20,20,14" Background="{StaticResource AccentBrush}" BorderThickness="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="SQL Server 定时导出工具" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#FFE2EEF3"
                               TextWrapping="Wrap"
                               Text="支持按导出格式和导出模式导出数据，可导出全部、最新记录或指定范围，并自动生成带时间戳的存档文件。" />
                </StackPanel>

                <Border Grid.Column="1"
                        VerticalAlignment="Center"
                        Background="#1FFFFFFF"
                        BorderThickness="0"
                        Padding="14,10">
                    <StackPanel>
                        <TextBlock Foreground="#FFE2EEF3" Text="下次执行" />
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="{Binding NextRunDisplay}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,0,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.6*" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <Border Margin="0,0,14,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="连接与导出配置" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#FF66584A"
                                       Text="先填写数据库连接信息，再配置导出格式、导出模式和筛选参数。" />
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,14,0">
                                <TextBlock FontWeight="SemiBold" Text="服务器 IP / 主机名" />
                                <TextBox Text="{Binding ServerHost, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                <TextBlock FontWeight="SemiBold" Text="端口" />
                                <TextBox Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Grid.RowSpan="3" Margin="0,24,0,0">
                                <Button Width="140" Click="LoadDatabases_Click" Style="{StaticResource PrimaryButtonStyle}" Content="加载数据库" />
                                <Button Width="140" Click="TestConnection_Click" Content="测试连接" />
                                <Button Width="140" Margin="0,10,0,0" Click="LoadTables_Click" Content="加载表" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,12,14,0">
                                <TextBlock FontWeight="SemiBold" Text="账号" />
                                <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,12,14,0">
                                <TextBlock FontWeight="SemiBold" Text="密码" />
                                <PasswordBox x:Name="PasswordInput" PasswordChanged="PasswordBox_OnPasswordChanged" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,12,14,0" Grid.ColumnSpan="2">
                                <TextBlock FontWeight="SemiBold" Text="数据库" />
                                <ComboBox ItemsSource="{Binding Databases}"
                                          SelectedItem="{Binding SelectedDatabase, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,14,0">
                                <TextBlock FontWeight="SemiBold" Text="导出格式" />
                                <ComboBox ItemsSource="{Binding ExportFormats}"
                                          SelectedItem="{Binding SelectedExportFormat, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                <TextBlock FontWeight="SemiBold" Text="导出模式" />
                                <ComboBox ItemsSource="{Binding ExportModes}"
                                          SelectedItem="{Binding SelectedExportMode, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock FontWeight="SemiBold" Text="筛选值类型" />
                                <ComboBox ItemsSource="{Binding FilterDataTypes}"
                                          SelectedItem="{Binding SelectedFilterDataType, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,12,14,0">
                                <TextBlock FontWeight="SemiBold" Text="筛选 / 排序字段" />
                                <TextBox Text="{Binding FilterColumn, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,12,14,0">
                                <TextBlock FontWeight="SemiBold" Text="最新记录数量" />
                                <TextBox Text="{Binding LatestRowCountText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock FontWeight="SemiBold" Text="文件命名规则" />
                                <TextBlock Margin="0,10,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="#FF66584A"
                                           Text="文件名会自动包含导出格式、导出模式和筛选条件信息。" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,14,0">
                                <TextBlock FontWeight="SemiBold" Text="范围开始值" />
                                <TextBox Text="{Binding RangeStart, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock FontWeight="SemiBold" Text="范围结束值" />
                                <TextBox Text="{Binding RangeEnd, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="4" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="导出目录" />
                                <TextBox Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="14,24,0,0">
                                <Button Click="BrowseDirectory_Click" Content="选择目录" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="14,0,14,0">
                                <TextBlock FontWeight="SemiBold" Text="执行周期（分钟）" />
                                <TextBox Text="{Binding IntervalMinutesText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock FontWeight="SemiBold" Text="启动时自动开启" />
                                <CheckBox Margin="0,12,0,0"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding AutoStartScheduler}"
                                          Content="读取配置后自动启动定时器" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="5" Margin="0,18,0,0" Background="{StaticResource AccentSoftBrush}">
                            <StackPanel>
                                <WrapPanel>
                                    <Button Click="SaveSettings_Click" Style="{StaticResource PrimaryButtonStyle}" Content="保存配置" />
                                    <Button Click="ExportNow_Click" Style="{StaticResource PrimaryButtonStyle}" Content="立即导出" />
                                    <Button Click="StartSchedule_Click" Style="{StaticResource PrimaryButtonStyle}" Content="启动定时" />
                                    <Button Click="StopSchedule_Click" Content="停止定时" />
                                </WrapPanel>
                                <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="运行状态" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Text="{Binding StatusMessage}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#FF5B6A6F"
                                           TextWrapping="Wrap"
                                           Text="CSV 导出会为每个表生成一个结构 JSON 文件和一个数据 CSV 文件。" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.2*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <Border Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="待导出的表" />
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,10">
                            <Button Click="SelectAllTables_Click" Style="{StaticResource PrimaryButtonStyle}" Content="全选" />
                            <Button Click="ClearSelectedTables_Click" Content="清空选择" />
                        </StackPanel>

                        <ListBox Grid.Row="2" ItemsSource="{Binding Tables}" BorderThickness="0" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Margin="0,4"
                                              IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              Content="{Binding DisplayName}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="执行日志" />
                        <ListBox Grid.Row="1"
                                 Margin="0,14,0,0"
                                 ItemsSource="{Binding Logs}"
                                 BorderThickness="0"
                                 Background="Transparent" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Margin="20,0,20,20" Padding="14,12">
            <TextBlock Foreground="#FF66584A"
                       Text="模式说明：全部导出会导出整表数据；最新导出会按筛选字段倒序取前 N 条；范围导出会导出筛选字段介于开始值和结束值之间的数据。" />
        </Border>
    </Grid>
</Window>
